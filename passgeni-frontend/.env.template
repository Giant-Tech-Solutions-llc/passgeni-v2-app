# =============================================================
# PASSGENI — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env.local for local development.
# Add ALL of these to Vercel: Settings → Environment Variables
# NEVER commit .env.local to git (it's in .gitignore)
# =============================================================

# ─── SITE ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://passgeni.ai
# For local dev: NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── RESEND (email) ──────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Get from: https://resend.com/audiences (create "PassGeni Waitlist")
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── LEMON SQUEEZY ───────────────────────────────────────────
# Get API key from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9.replace_with_api_key

# Get from: https://app.lemonsqueezy.com/settings/store → Store ID
LEMONSQUEEZY_STORE_ID=12345

# After creating the Team product + variant in LS:
#   1. Go to LemonSqueezy → Products → Create product
#   2. Name: "PassGeni Team", Price: $29/month (recurring)
#   3. Copy the Variant ID from Products → your product → Variants
LEMONSQUEEZY_VARIANT_TEAM_MONTHLY=67890

# Get from: https://app.lemonsqueezy.com/settings/webhooks
# After creating the webhook endpoint pointing to:
#   https://passgeni.ai/api/lemonsqueezy/webhook
# Events to subscribe to:
#   subscription_created
#   subscription_updated
#   subscription_cancelled
#   subscription_expired
#   subscription_payment_failed
LEMONSQUEEZY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── TEAM API KEYS (interim — Phase 3) ──────────────────────
# Comma-separated list of valid Team API keys.
# This is the Phase 3 interim approach.
# Phase 4 will replace this with database lookups.
#
# After a customer subscribes, the welcome email sends their key.
# Also add it here so the API accepts it immediately.
# Format: pg_live_key1,pg_live_key2,pg_live_key3
TEAM_API_KEYS=pg_live_replace_me,pg_live_another_one

# ─── NEXTAUTH (Phase 4) ──────────────────────────────────────
# The URL this app is deployed at (no trailing slash)
NEXTAUTH_URL=https://passgeni.ai
# For local dev: NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32_output

# ─── SUPABASE (Phase 4) ──────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
# Use the SERVICE ROLE key (not the anon key) — this is server-side only

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace_with_service_role_key

# ─── PHASE 4 SETUP STEPS ────────────────────────────────────
# 1. Create Supabase project at supabase.com
# 2. Run lib/db/schema.sql in Supabase SQL Editor
# 3. Run lib/db/functions.sql in Supabase SQL Editor
# 4. Add SUPABASE_URL and SUPABASE_SERVICE_KEY to Vercel
# 5. Generate NEXTAUTH_SECRET and add to Vercel
# 6. Set NEXTAUTH_URL to https://passgeni.ai in Vercel
# 7. Deploy: npx vercel --prod
# 8. Test: visit /auth/signin → enter email → click magic link → /dashboard

# ── Phase 6 additions ────────────────────────────────────────
# Internal secret for protecting internal API endpoints
# Generate: openssl rand -base64 32
INTERNAL_SECRET=<generate with openssl rand -base64 32>
